# Copy this file to .env.prod on the VPS and fill in real values.
# For local dev, copy to .env (DATABASE_URL only needed for migrations).

# ── Database (used at runtime by the app container) ───────────────────────────
# For docker-compose.prod.yml, these three build the DATABASE_URL automatically.
POSTGRES_USER=pan_user
POSTGRES_PASSWORD=CHANGE_ME_strong_password
POSTGRES_DB=pan_db

# ── Next.js app ───────────────────────────────────────────────────────────────
# Docker Compose injects DATABASE_URL from the three vars above — leave blank here.
DATABASE_URL=

TELEGRAM_BOT_TOKEN=your-bot-token-from-BotFather

# PAN's n8n instance — receives cashback events and sends Telegram messages
N8N_WEBHOOK_URL=https://your-n8n-instance.com/webhook

NEXT_PUBLIC_APP_URL=https://uat.cashbackapp.cloud

# ── docker-compose.prod.yml ───────────────────────────────────────────────────
# Port that the Next.js container binds to on the host
# UAT = 3000, production = 3001 (nginx proxies the right port per domain)
APP_PORT=3000
