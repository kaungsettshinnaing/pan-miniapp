# Copy this file to .env.prod on the VPS and fill in real values.
# For local dev, copy to .env (DATABASE_URL only needed for migrations).

# ── Database ───────────────────────────────────────────────────────────────────
POSTGRES_USER=pan_user
POSTGRES_PASSWORD=CHANGE_ME_strong_password
POSTGRES_DB=pan_db

# ── Next.js app ───────────────────────────────────────────────────────────────
# Docker Compose builds DATABASE_URL from the three vars above — leave blank.
DATABASE_URL=

TELEGRAM_BOT_TOKEN=your-bot-token-from-BotFather

# PAN's n8n instance — receives cashback events and sends Telegram messages
N8N_WEBHOOK_URL=

NEXT_PUBLIC_APP_URL=https://uat.cashbackapp.cloud

# ── Traefik routing ───────────────────────────────────────────────────────────
# The domain Traefik should route to this container
DOMAIN=uat.cashbackapp.cloud
# Unique router name per deployment — use pan-uat for UAT, pan-prod for production
APP_ENV=pan-uat
