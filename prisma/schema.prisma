generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model PlatformSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model RedemptionGroup {
  id          String     @id @default(cuid())
  groupName   String
  description String?
  merchants   Merchant[]
  webUsers    WebUser[]
  createdAt   DateTime   @default(now())
}

model Merchant {
  merchantURL              String           @id
  merchantName             String
  outletName               String?
  merchantTelegramID       String
  active                   Boolean          @default(true)
  botToken                 String?          // PAN admin only — if merchant has own bot
  earnType                 EarnType         @default(PERCENTAGE)
  earnValue                Float            @default(10) // % or fixed Ks amount
  commissionType           CommissionType   @default(PERCENTAGE)
  commissionBasis          CommissionBasis  @default(RETURN_TRANSACTION)
  commissionValue          Float            @default(0)
  subscriptionFee          Float            @default(0)
  rebateValidityDays       Int              @default(14)
  firstReminderDays        Int              @default(7)
  secondReminderDays       Int              @default(3)
  firstRecallCampaignDays  Int              @default(21)
  secondRecallCampaignDays Int              @default(30)
  redemptionGroupID        String?
  redemptionGroup          RedemptionGroup? @relation(fields: [redemptionGroupID], references: [id])
  cashbacks                Cashback[]
  purchases                Purchase[]
  otpSessions              OtpSession[]
  messageTemplates         MessageTemplate[]
  billing                  MonthlyBilling[]
  webUsers                 WebUser[]        @relation("MerchantLogin")
  channelPartnerID         String?
  channelPartner           WebUser?         @relation("ChannelPartnerMerchants", fields: [channelPartnerID], references: [id])
  reminderSendTime         String           @default("09:00") // HH:MM in GMT+6.5 — hour n8n must fire for expiry reminders
  winbackSendTime          String           @default("17:00") // HH:MM in GMT+6.5 — hour n8n must fire for win-back campaigns
  notificationLogs         NotificationLog[]
  createdAt                DateTime         @default(now())
  updatedAt                DateTime         @updatedAt
}

model Customer {
  customerTelegramID String     @id
  username           String?
  firstName          String?
  lastName           String?
  phoneNumber        String?
  birthday           DateTime?
  cashbacks          Cashback[]
  purchases          Purchase[]
  otpSessions        OtpSession[]
  notificationLogs   NotificationLog[]
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt
}

model Cashback {
  id                 String    @id @default(cuid())
  merchantURL        String
  customerTelegramID String
  cashbackAmt            Float
  originalPurchaseAmount Float    @default(0)   // gross purchase that generated this cashback
  expiryDate             DateTime
  redeemed               Boolean  @default(false)
  redemptionDate         DateTime?
  merchant           Merchant  @relation(fields: [merchantURL], references: [merchantURL])
  customer           Customer  @relation(fields: [customerTelegramID], references: [customerTelegramID])
  createdAt          DateTime  @default(now())

  @@index([merchantURL, customerTelegramID, redeemed, expiryDate])
}

model Purchase {
  id                 String   @id @default(cuid())
  merchantURL        String
  customerTelegramID String
  amount             Float
  rebateDeducted     Float    @default(0)
  commissionEarned   Float    @default(0)
  note               String?
  merchant           Merchant @relation(fields: [merchantURL], references: [merchantURL])
  customer           Customer @relation(fields: [customerTelegramID], references: [customerTelegramID])
  createdAt          DateTime @default(now())

  @@index([merchantURL, customerTelegramID, createdAt])
}

model OtpSession {
  id                 String    @id @default(cuid())
  customerTelegramID String
  merchantURL        String
  otpCode            String    // 4-digit code
  totalCashback      Float
  expiresAt          DateTime
  used               Boolean   @default(false)
  cancelled          Boolean   @default(false)
  cancelledAt        DateTime?
  resultMessage      Json?     // resolved customerMessage stored after successful redemption (for customer polling)
  merchant           Merchant  @relation(fields: [merchantURL], references: [merchantURL])
  customer           Customer  @relation(fields: [customerTelegramID], references: [customerTelegramID])
  createdAt          DateTime  @default(now())

  @@index([otpCode, merchantURL, used, expiresAt])
  @@index([customerTelegramID, used, cancelled, expiresAt])
}

model MessageTemplate {
  id          String          @id @default(cuid())
  merchantURL String
  platform    Platform        @default(TELEGRAM)
  trigger     MessageTrigger
  messageText String?         // supports {{variables}}
  imageURL    String?
  merchant    Merchant        @relation(fields: [merchantURL], references: [merchantURL])
  updatedAt   DateTime        @updatedAt

  @@unique([merchantURL, platform, trigger])
}

model MonthlyBilling {
  id              String   @id @default(cuid())
  merchantURL     String
  billingMonth    String   // "YYYY-MM"
  totalCommission Float    @default(0)
  subscriptionFee Float    @default(0)
  totalDue        Float    @default(0)
  paid            Boolean  @default(false)
  merchant        Merchant @relation(fields: [merchantURL], references: [merchantURL])
  createdAt       DateTime @default(now())

  @@unique([merchantURL, billingMonth])
}

model WebUser {
  id                String           @id @default(cuid())
  username          String           @unique
  passwordHash      String
  role              WebUserRole
  merchantURL       String?          // MERCHANT — single outlet
  merchant          Merchant?        @relation("MerchantLogin", fields: [merchantURL], references: [merchantURL])
  redemptionGroupID String?          // MERCHANT — group owner (sees all outlets in group)
  redemptionGroup   RedemptionGroup? @relation(fields: [redemptionGroupID], references: [id])
  profitSharePct    Float?           // CHANNEL_PARTNER — % of commission, set by admin
  managedMerchants  Merchant[]       @relation("ChannelPartnerMerchants")
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
}

enum WebUserRole {
  ADMIN
  MERCHANT
  CHANNEL_PARTNER
}

enum EarnType {
  PERCENTAGE
  FIXED
}

enum CommissionType {
  PERCENTAGE
  FLAT
}

enum CommissionBasis {
  RETURN_TRANSACTION    // commission % on current visit's gross purchase
  INITIAL_TRANSACTION  // commission % on the purchase that generated the redeemed cashback
}

enum Platform {
  TELEGRAM
}

model NotificationLog {
  id                 String         @id @default(cuid())
  customerTelegramID String
  merchantURL        String
  trigger            MessageTrigger
  sentAt             DateTime       @default(now())
  customer           Customer       @relation(fields: [customerTelegramID], references: [customerTelegramID])
  merchant           Merchant       @relation(fields: [merchantURL], references: [merchantURL])

  @@index([customerTelegramID, merchantURL, trigger, sentAt])
}

enum MessageTrigger {
  CASHBACK_ISSUED
  CASHBACK_ISSUED_WITH_REDEMPTION
  CASHBACK_ISSUED_NO_PRIOR_BALANCE
  REDEMPTION_FAILURE
  REDEMPTION_CANCELLED
  EXPIRY_FIRST_REMINDER
  EXPIRY_SECOND_REMINDER
  FIRST_RECALL_CAMPAIGN
  SECOND_RECALL_CAMPAIGN
}
