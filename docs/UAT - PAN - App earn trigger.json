    {
      "parameters": {
        "operation": "sendAndWait",
        "chatId": "={{ $('Webhook').item.json.body.merchantTelegramID }}",
        "message": "=🔔🔔🔔\n\nဆိုင်မှာ ဝယ်ယူသူ {{ $('Webhook').item.json.body.customerName }} က {{ $('Webhook').item.json.body.totalCashback }} ကျပ် ငွေပြန်အမ်းငွေကို ရယူဖို့ ကြိုးစားနေပါတယ်\n\nဝယ်ယူသူ၏ OTP ကို redeem ကို နှိပ်ပြီးနောက်​​ရိုက်ထည့်ပါ",
        "responseType": "customForm",
        "formFields": {
          "values": [
            {
              "fieldLabel": "OTP",
              "fieldType": "number",
              "requiredField": true
            },
            {
              "fieldLabel": "Amount",
              "fieldType": "number",
              "requiredField": true
            },
            {
              "fieldLabel": "Note",
              "fieldType": "textarea"
            }
          ]
        },
        "options": {
          "messageButtonLabel": "Redeem",
          "appendAttribution": false
        }
      },
      "type": "n8n-nodes-base.telegram",
